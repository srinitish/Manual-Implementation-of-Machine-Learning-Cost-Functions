   "source": [
    "import numpy as np\n",
    "y = np.array([1,1,0,0,1])\n",
    "y_pred = np.array([0.30,0.7,1,0,0.5])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "28d9c019",
   "metadata": {},
   "outputs": [],
   "source": [
    "def mse(y,y_pred):\n",
    "    total_error = 0\n",
    "    for ya,yp in zip(y,y_pred):\n",
    "        total_error += (ya-yp)**2\n",
    "    mse = total_error/len(y)\n",
    "    return mse "
   ]
  },
